  "info": {
    "_postman_id": "0c5f5053-4838-49e5-a2f4-fd3f8f903aad",
    "name": "State Street Fund Connect API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The State Street Fund Connect API enables authorized participants (APs), ETF fund managers, and custodians to programmatically manage ETF creation and redemption orders through the Fund Connect platform. Fund Connect is a global online portal for the creation and redemption of ETFs. The API supports automated order entry, basket composition retrieval, order status tracking, and settlement confirmation. In 2025, Fund Connect executed the first API-based ETF order for an Australian-domiciled ETF. The platform processes ETF transactions across all major markets. Authentication uses OAuth 2.0 Client Credentials per RFC 6749 Section 4.4.2.\n\nContact Support:\n Name: State Street API Support\n Email: api-support@statestreet.com",
      "type": "text/plain"
    }
  }
